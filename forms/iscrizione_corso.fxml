<?xml version="1.0" encoding="UTF-8"?>
<form id="iscrizione_corso_uni" title="Domanda di iscrizione al corso di laurea" lang="it" version="1.0" author="Università degli Studi di Esempio">

  <variables>
    <var name="eta" expr="today.year - data_nascita.year - ((today.month, today.day) &lt; (data_nascita.month, data_nascita.day))" />
    <var name="maggiorenne" expr="eta >= 18" />
    <var name="diploma_estero" expr="paese_diploma != 'IT'" />
    <var name="vuole_borsa" expr="richiede_borsa == True" />
  </variables>

  <section title="Dati anagrafici">
    <row>
      <text>Il sottoscritto </text>
      <textfield name="cognome" label="Cognome" required="true" width="2" />
      <textfield name="nome" label="Nome" required="true" width="2" />
    </row>
    <row>
      <text>Nato/a a</text>
      <textfield name="comune_nascita" label="Comune" required="true" width="2" />
      <textfield name="provincia_nascita" label="Prov." maxlength="2" width="1" />
      <text>il</text>
      <datefield name="data_nascita" label="Data di nascita" required="true" max="2007-12-31" />
    </row>
    <row>
      <textfield name="cf" label="Codice Fiscale" required="true" maxlength="16">
        <validate pattern="[A-Z]{6}[0-9]{2}[A-Z][0-9]{2}[A-Z][0-9]{3}[A-Z]"
                  message="Codice fiscale non valido. Inserire 16 caratteri in maiuscolo." />
      </textfield>
      <selectfield name="sesso" label="Sesso" required="true">
        <option value="M">Maschio</option>
        <option value="F">Femmina</option>
        <option value="ND">Preferisco non specificare</option>
      </selectfield>
    </row>
    <row>
      <selectfield name="cittadinanza" label="Cittadinanza" required="true">
        <option value="IT">Italiana</option>
        <option value="UE">Unione Europea</option>
        <option value="EXTRA_UE">Extra UE</option>
      </selectfield>
      <textfield name="passaporto" label="N° Passaporto / Permesso di soggiorno" />
    </row>
  </section>

  <conditional if="not $maggiorenne">
    <section title="Dati tutore legale">
      <row>
        <textfield name="tutore_cognome" label="Cognome tutore" required="true" />
        <textfield name="tutore_nome" label="Nome tutore" required="true" />
      </row>
      <row>
        <textfield name="tutore_cf" label="Codice Fiscale tutore" required="true" maxlength="16" />
        <textfield name="tutore_telefono" label="Telefono tutore" required="true" />
      </row>
    </section>
  </conditional>

  <section title="Residenza">
    <row>
      <textfield name="via" label="Via/Piazza e numero civico" required="true" width="3" />
    </row>
    <row>
      <textfield name="comune_res" label="Comune" required="true" width="2" />
      <textfield name="provincia_res" label="Prov." maxlength="2" width="1" />
      <textfield name="cap" label="CAP" required="true" maxlength="5" width="1">
        <validate pattern="[0-9]{5}" message="CAP non valido." />
      </textfield>
    </row>
  </section>

  <section title="Contatti">
    <row>
      <emailfield name="email" label="Indirizzo e-mail" required="true" width="2" />
      <phonefield name="telefono" label="Telefono" required="true" width="1" />
    </row>
  </section>

  <section title="Titolo di studio">
    <row>
      <selectfield name="tipo_diploma" label="Tipo di diploma" required="true">
        <option value="classico">Liceo Classico</option>
        <option value="scientifico">Liceo Scientifico</option>
        <option value="linguistico">Liceo Linguistico</option>
        <option value="tecnico">Istituto Tecnico</option>
        <option value="professionale">Istituto Professionale</option>
        <option value="altro">Altro</option>
      </selectfield>
      <numberfield name="voto_diploma" label="Voto di diploma (su 100)" required="true" min="60" max="100" step="1" />
    </row>
    <row>
      <textfield name="istituto" label="Nome dell'istituto scolastico" required="true" width="2" />
      <selectfield name="paese_diploma" label="Paese" required="true">
        <option value="IT">Italia</option>
        <option value="DE">Germania</option>
        <option value="FR">Francia</option>
        <option value="ES">Spagna</option>
        <option value="ALTRO">Altro</option>
      </selectfield>
    </row>
    <row>
      <datefield name="data_diploma" label="Data di conseguimento" required="true" />
    </row>
  </section>

  <conditional if="$diploma_estero">
    <section title="Riconoscimento titolo estero">
      <row>
        <text>Il diploma conseguito all'estero deve essere accompagnato da una dichiarazione di valore. Indicare il numero di protocollo:</text>
      </row>
      <row>
        <textfield name="dichiarazione_valore" label="N° dichiarazione di valore" required="true" />
        <datefield name="data_dichiarazione" label="Data rilascio" required="true" />
      </row>
    </section>
  </conditional>

  <section title="Corso di laurea richiesto">
    <row>
      <selectfield name="corso" label="Corso di laurea" required="true">
        <option value="INF">Informatica (L-31)</option>
        <option value="ING_INF">Ingegneria Informatica (L-8)</option>
        <option value="MAT">Matematica (L-35)</option>
        <option value="FIS">Fisica (L-30)</option>
      </selectfield>
      <radiogroup name="ciclo" label="Ciclo">
        <option value="triennale">Triennale</option>
        <option value="magistrale">Magistrale</option>
      </radiogroup>
    </row>
    <row>
      <textarea name="motivazione" label="Motivazione alla scelta del corso (max 500 caratteri)" rows="4" maxlength="500" />
    </row>
  </section>

  <section title="Agevolazioni e borse di studio">
    <row>
      <checkfield name="richiede_borsa" label="Desidero richiedere una borsa di studio / agevolazione economica (ISEE)" />
    </row>
  </section>

  <conditional if="$vuole_borsa">
    <section title="Dati ISEE">
      <row>
        <numberfield name="isee" label="Valore ISEE (€)" required="true" min="0" max="100000" step="0.01" />
        <datefield name="data_isee" label="Data rilascio attestazione ISEE" required="true" />
      </row>
      <row>
        <textfield name="protocollo_isee" label="N° protocollo attestazione ISEE" required="true" />
      </row>
    </section>
  </conditional>

  <section title="Dichiarazioni del richiedente">
    <row>
      <text>Il/La sottoscritto/a</text><printvar name="nome" /> <printvar name="cognome" /><text>, consapevole delle responsabilità penali previste per le dichiarazioni false, dichiara che:</text>
    </row>
    <row>
      <checkfield name="dich_verita" label="Tutte le informazioni fornite nel presente modulo sono veritiere e documentabili." required="true" />
    </row>
    <row>
      <checkfield name="privacy" label="Acconsento al trattamento dei dati personali ai sensi del Regolamento UE 2016/679 (GDPR)." required="true" />
    </row>
    <row>
      <checkfield name="comunicazioni" label="Acconsento a ricevere comunicazioni istituzionali via e-mail all'indirizzo indicato." />
    </row>
  </section>

  <section title="Riepilogo">
    <row>
      <computed name="riepilogo_nome" label="Richiedente" value="$cognome $nome" />
      <computed name="riepilogo_eta" label="Età" value="$eta" />
    </row>
    <row>
      <computed name="riepilogo_corso" label="Corso selezionato" value="$corso" />
    </row>
  </section>

</form>
